# ─── InvoKash Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Telegram Bot Token — get from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Anthropic (Claude) API Key — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (for Whisper voice transcription) — https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Stripe Secret Key — https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=your_stripe_secret_key_here
