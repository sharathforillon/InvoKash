# ─── InvoKash v2 Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ─── AI / Claude ──────────────────────────────────────────────────────────────
# Anthropic Claude API key — https://console.anthropic.com
# Used for: intent classification & invoice data extraction (Haiku model for cost efficiency)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key — https://platform.openai.com
# Used for: voice message transcription (Whisper model)
OPENAI_API_KEY=your_openai_api_key_here

# ─── Payments ─────────────────────────────────────────────────────────────────
# Stripe secret key — https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# ─── WhatsApp Business Cloud API ──────────────────────────────────────────────
# Setup guide: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
#
# 1. Create a Meta Developer App at https://developers.facebook.com
# 2. Add WhatsApp product to your app
# 3. Get a test phone number from the WhatsApp Business API setup
# 4. Generate a permanent access token from Meta Business Manager
#
# Your WhatsApp Business API access token (from Meta Developer Console)
WHATSAPP_TOKEN=your_whatsapp_access_token_here

# Your WhatsApp Business Phone Number ID (from Meta Developer Console)
WHATSAPP_PHONE_ID=your_phone_number_id_here

# A secret token you choose — used to verify webhook authenticity
WHATSAPP_VERIFY_TOKEN=invokash_webhook_secret_2024

# Port for the WhatsApp webhook server (default: 3000)
# For production, use a reverse proxy (nginx/caddy) with HTTPS
PORT=3000

# ─── Email (SMTP) — enables "Send to Client Email" on every invoice ───────────
# Supports Gmail, Outlook/Office365, Amazon SES, Zoho, or any SMTP server.
# Leave blank to disable email sending (WhatsApp still works without this).
#
# Gmail setup:
#   1. Enable 2-Step Verification at https://myaccount.google.com/security
#   2. Create an App Password at https://myaccount.google.com/apppasswords
#   3. Use that 16-char App Password as SMTP_PASS (NOT your Gmail password)
#
# Office 365 / Outlook: host=smtp.office365.com port=587
# Amazon SES:           host=email-smtp.<region>.amazonaws.com port=587
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
# Display name shown in the From field (e.g. "Ahmed – InvoKash")
SMTP_FROM=InvoKash Invoicing

# ─── Optional: Business Support ───────────────────────────────────────────────
# Support contact shown in help messages
SUPPORT_USERNAME=InvoKashSupport
